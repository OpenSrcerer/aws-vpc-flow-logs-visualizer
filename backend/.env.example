DJANGO_DEBUG=true
DJANGO_SECRET_KEY=change-me
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOW_ALL_ORIGINS=true
# Optional: override SQLite with PostgreSQL URL
# DJANGO_DATABASE_URL=postgresql://user:password@localhost:5432/aws_vpc_flow_logs
# Optional: enable API login via HTTP Basic auth when set.
# WRITE_ACCOUNT has read/write access.
# READ_ACCOUNT has read-only access.
# WRITE_ACCOUNT=admin:admin
# READ_ACCOUNT=user:user
